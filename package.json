  "devDependencies": {
    "@4tw/cypress-drag-drop": "^2.3.1",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "cypress": "^13.17.0",
    "cypress-drag-drop": "^1.1.1",
    "cypress-real-events": "^1.15.0",
    "papaparse": "^5.4.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
