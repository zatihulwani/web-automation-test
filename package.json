{
  "name": "web-automation-test",
  "version": "1.0.0",
  "description": "Automation test untuk DemoQA Web Tables menggunakan Cypress, TypeScript, dan data CSV",
  "main": "index.js",
  "scripts": {
    "test": "cypress open",
    "test:headless": "cypress run",
    "test:headed": "cypress run --headed",
